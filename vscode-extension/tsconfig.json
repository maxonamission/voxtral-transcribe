{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2022",
		"lib": ["ES2022"],
		"moduleResolution": "bundler",
		"strict": true,
		"strictNullChecks": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"outDir": "dist",
		"rootDir": "src",
		"sourceMap": true,
		"declaration": false,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["__tests__/**", "vitest.config.ts", "dist"]
}
